flowchart TB
    subgraph USER["Your Code"]
        direction LR
        U1["pk.elements.get(name='CNC-Mill')"]
        U2["machine.signals()"]
        U3["sig.data(last='1h')"]
        U4["pk.tree().print()"]
        U5["pk.query(sql)"]
        U6["machine.help()"]
    end

    subgraph SDK["prekit-sdk"]
        direction TB

        subgraph CLIENT["client.py — Prekit"]
            C1["connect() / connect_from_env()"]
            C2["tree() / query() / health()"]
            C3["get_latest() / print_latest()"]
        end

        subgraph AUTH["auth.py"]
            A1["ApiKeyAuthProvider"]
            A2["OAuthAuthProvider — Keycloak"]
            A3["AzureAuthProvider — MSAL"]
            A4["AutoRefreshApiClient"]
        end

        subgraph MANAGERS["managers.py — Django-style"]
            M1["ElementManager"]
            M2["SignalManager"]
            M3["TagManager / TagContextManager"]
            M4[".get() / .filter() / .all() / .create()"]
        end

        subgraph MODELS["models.py — __getattr__ proxy"]
            MO1["Element — .signals() .children() .parent() .path()"]
            MO2["Signal — .element() .data() .latest()"]
            MO3["Tag / TagContext — .service() .signal()"]
            MO4[".help() — introspects _raw.model_fields"]
        end

        subgraph TREE["tree.py"]
            T1["Tree / TreeNode"]
            T2["ASCII printer — compact + signals"]
            T3["find() / find_by_path() / resolve_signals()"]
            T4["Raw HTTP to /simple-tree/ — bypasses Pydantic"]
        end

        subgraph HIST["historian.py + helpers.py"]
            H1["fetch_signal_data() / fetch_element_data()"]
            H2["parse_duration — '1h', '7d'"]
            H3["Returns pandas DataFrames"]
        end
    end

    subgraph GENERATED["prekit_edge_node_api — auto-generated by CI/CD"]
        direction TB
        G1["106 API classes — SignalApi, SystemElementApi, ..."]
        G2["119+ Pydantic models — Signal, SystemElement, ..."]
        G3["ApiClient — HTTP + auth headers"]
        G4["Regenerated on every API change — new fields appear automatically"]
    end

    subgraph API["PREKIT Edge/Hub API"]
        direction LR
        API1["REST endpoints"]
        API2["TimescaleDB — historian"]
        API3["simple-tree — hierarchy"]
        API4["latest-values"]
    end

    USER --> SDK
    CLIENT --> AUTH
    CLIENT --> MANAGERS
    CLIENT --> TREE
    CLIENT --> HIST
    MANAGERS --> MODELS
    MODELS -->|"__getattr__ delegates"| G2
    MANAGERS -->|"getattr(prekit, 'SignalApi')"| G1
    AUTH -->|"wraps"| G3
    HIST -->|"MetricApi / QueryDatabaseApi"| G1
    T4 -->|"pool_manager.request()"| API3
    GENERATED --> API

    style USER fill:#dcfce7,stroke:#22c55e,stroke-width:2px,color:#1e293b
    style SDK fill:#f1f5f9,stroke:#134562,stroke-width:2px,color:#1e293b
